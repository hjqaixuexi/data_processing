import {
    Button,
    HorizontalBox,
    ScrollView,
    VerticalBox,
} from "std-widgets.slint";
import {
    AppState,
    ColumnRowData,
    DatasetCardData,
    FormState,
    IssueRowData,
    JoinSuggestionData,
    Logic,
    MappingRowData,
    MetricCardData,
    PreviewRowData,
    StepRowData,
} from "models.slint";
import { AppTheme } from "theme.slint";
import {
    DatasetRow,
    LabeledChoice,
    LabeledField,
    MetricTile,
    Panel,
    StatusTag,
    TabButton,
} from "widgets.slint";

export {
    AppState,
    ColumnRowData,
    DatasetCardData,
    FormState,
    IssueRowData,
    JoinSuggestionData,
    Logic,
    MappingRowData,
    MetricCardData,
    PreviewRowData,
    StepRowData,
}from "models.slint";

component SummaryLine inherits Rectangle {
    in property <string> label;
    in property <string> value;

    min-height: 26px;
    background: AppTheme.panel-muted;
    border-width: 1px;
    border-color: AppTheme.border;

    HorizontalBox {
        width: parent.width;
        height: parent.height;
        padding-left: 8px;
        padding-right: 8px;
        spacing: 6px;

        Text {
            width: 78px;
            text: root.label;
            color: AppTheme.text-soft;
            font-size: 10px;
            font-weight: 600;
        }

        Text {
            horizontal-stretch: 1;
            text: root.value;
            color: AppTheme.text;
            font-size: 10px;
            wrap: word-wrap;
        }
    }
}

component InfoCard inherits Rectangle {
    in property <string> title;
    in property <string> value;
    in property <length> card-min-height: 72px;

    min-height: root.card-min-height;
    background: AppTheme.panel-muted;
    border-width: 1px;
    border-color: AppTheme.border;
    border-radius: 3px;

    VerticalBox {
        width: parent.width;
        height: parent.height;
        padding-left: 8px;
        padding-right: 8px;
        padding-top: 6px;
        padding-bottom: 6px;
        spacing: 4px;

        Text {
            text: root.title;
            color: AppTheme.text-soft;
            font-size: 10px;
            font-weight: 600;
        }

        Text {
            text: root.value;
            color: AppTheme.text;
            font-size: 10px;
            wrap: word-wrap;
        }
    }
}

component InlineActionButton inherits VerticalBox {
    in property <string> label;
    in property <bool> primary: false;
    callback pressed();

    spacing: 2px;

    Rectangle {
        height: 14px;
    }

    Button {
        text: root.label;
        primary: root.primary;
        height: 28px;
        clicked => { root.pressed(); }
    }
}

component InlineToggleButton inherits VerticalBox {
    in property <string> label;
    in-out property <bool> checked;

    spacing: 2px;

    Rectangle {
        height: 14px;
    }

    Button {
        text: root.label;
        checkable: true;
        checked <=> root.checked;
        height: 28px;
    }
}

component PagerBadge inherits Rectangle {
    in property <string> label;

    width: 92px;
    height: 28px;
    background: AppTheme.panel-bg;
    border-width: 1px;
    border-color: AppTheme.border;
    border-radius: 3px;

    Text {
        width: parent.width;
        height: parent.height;
        text: root.label;
        color: AppTheme.text;
        font-size: 10px;
        font-weight: 600;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
}

component LedgerHeaderCell inherits Rectangle {
    in property <string> label;
    in property <length> cell-width;
    in property <bool> center: false;

    width: root.cell-width;
    height: 28px;
    background: AppTheme.rail-bg;
    border-width: 1px;
    border-color: AppTheme.border;
    clip: true;

    Text {
        x: 6px;
        y: 6px;
        width: parent.width - 12px;
        text: root.label;
        color: AppTheme.text-soft;
        font-size: 10px;
        font-weight: 700;
        horizontal-alignment: root.center ? TextHorizontalAlignment.center : TextHorizontalAlignment.left;
        wrap: no-wrap;
    }
}

component LedgerCell inherits Rectangle {
    in property <string> value;
    in property <length> cell-width;
    in property <bool> alternate: false;
    in property <bool> center: false;

    width: root.cell-width;
    height: 28px;
    background: root.alternate ? #fbfcfe : AppTheme.panel-bg;
    border-width: 1px;
    border-color: AppTheme.border;
    clip: true;

    Text {
        x: 6px;
        y: 6px;
        width: parent.width - 12px;
        text: root.value;
        color: AppTheme.text;
        font-size: 10px;
        horizontal-alignment: root.center ? TextHorizontalAlignment.center : TextHorizontalAlignment.left;
        wrap: no-wrap;
    }
}

component IssueRow inherits Rectangle {
    in property <string> category;
    in property <string> severity;
    in property <string> field;
    in property <string> detail;

    min-height: 34px;
    background: AppTheme.panel-bg;
    border-width: 1px;
    border-color: AppTheme.border;

    HorizontalBox {
        width: parent.width;
        height: parent.height;
        spacing: 0px;

        LedgerCell {
            cell-width: 96px;
            value: root.category;
        }

        LedgerCell {
            cell-width: 64px;
            value: root.severity;
            center: true;
        }

        LedgerCell {
            cell-width: 180px;
            value: root.field;
        }

        LedgerCell {
            cell-width: 620px;
            value: root.detail;
        }
    }
}

component StepRow inherits Rectangle {
    in property <string> time;
    in property <string> action;
    in property <string> detail;
    in property <string> outcome;

    min-height: 34px;
    background: AppTheme.panel-bg;
    border-width: 1px;
    border-color: AppTheme.border;

    HorizontalBox {
        width: parent.width;
        height: parent.height;
        spacing: 0px;

        LedgerCell {
            cell-width: 78px;
            value: root.time;
            center: true;
        }

        LedgerCell {
            cell-width: 160px;
            value: root.action;
        }

        LedgerCell {
            cell-width: 430px;
            value: root.detail;
        }

        LedgerCell {
            cell-width: 280px;
            value: root.outcome;
        }
    }
}

export component MainWindow inherits Window {
    in-out property <int> active-tab: 0;
    private property <length> page-padding: 0px;
    private property <length> sidebar-width: 316px;
    private property <length> preview-col-width: root.width > 1600px ? 154px : 136px;
    private property <length> preview-scroll-gutter: root.preview-col-width;
    private property <length> preview-table-width: 54px + AppState.preview-columns.length * root.preview-col-width;
    private property <length> table-scrollbar-gutter: 12px;
    private property <length> issue-table-width: 960px;
    private property <length> field-table-width: 812px;
    private property <length> cleaning-panel-gap: 8px;
    private property <length> cleaning-bottom-padding: 320px;
    private property <length> cleaning-content-height: 148px + 168px + 148px + 178px + 172px + 4 * root.cleaning-panel-gap + root.cleaning-bottom-padding;
    private property <length> derive-panel-gap: 8px;
    private property <length> derive-bottom-padding: 260px;
    private property <length> derive-content-height: 256px + 148px + 236px + 300px + 3 * root.derive-panel-gap + root.derive-bottom-padding;
    private property <length> join-panel-gap: 8px;
    private property <length> join-bottom-padding: 48px;
    private property <length> pipeline-panel-gap: 8px;
    private property <length> pipeline-bottom-padding: 48px;

    title: "工程数据处理台";
    icon: @image-url("assets/data_processing.png");
    preferred-width: 1300px;
    preferred-height: 800px;
    min-width: 1500px;
    min-height: 940px;
    background: AppTheme.window-bg;

    main_menu := MenuBar {
        Menu {
            title: "文件";

            MenuItem {
                title: "导入文件";
                activated => { Logic.import-files(); }
            }

            MenuItem {
                title: "删除当前数据集";
                activated => { Logic.delete-selected-dataset(); }
            }
        }

        Menu {
            title: "编辑";

            MenuItem {
                title: "撤销";
                activated => { Logic.undo(); }
            }

            MenuItem {
                title: "重做";
                activated => { Logic.redo(); }
            }
        }

        Menu {
            title: "数据";

            MenuItem {
                title: "复检当前数据集";
                activated => { Logic.refresh-current(); }
            }
        }

        Menu {
            title: "导出";

            MenuItem {
                title: "导出 CSV";
                activated => { Logic.export-csv(); }
            }

            MenuItem {
                title: "导出 TSV";
                activated => { Logic.export-tsv(); }
            }

            MenuItem {
                title: "导出 TXT";
                activated => { Logic.export-txt(); }
            }

            MenuItem {
                title: "质量报告 PDF";
                activated => { Logic.export-quality-report(); }
            }
        }
    }

    content := Rectangle {
        x: 0px;
        y: 0px;
        width: root.width;
        height: root.height;
        background: transparent;
        clip: false;

        HorizontalBox {
            x: 0px;
            y: 0px;
            width: parent.width;
            height: parent.height;
            spacing: root.page-padding;

            VerticalBox {
                width: root.sidebar-width;
                height: parent.height;
                spacing: root.page-padding;
                padding-bottom: 10px;

                Panel {
                    title: "已导入数据集";
                    subtitle: "";
                    vertical-stretch: 1;

                    Rectangle {
                        min-height: 0px;
                        background: AppTheme.rail-bg;
                        border-width: 1px;
                        border-color: AppTheme.border;

                        dataset-scroll := ScrollView {
                            x: 0px;
                            y: 0px;
                            width: parent.width;
                            height: parent.height;
                            horizontal-scrollbar-policy: ScrollBarPolicy.always-off;
                            viewport-width: self.visible-width;

                            dataset-list := VerticalBox {
                                width: dataset-scroll.visible-width;
                                spacing: 4px;
                                padding: 4px;

                                for dataset in AppState.datasets: DatasetRow {
                                    width: dataset-list.width - 8px;
                                    dataset: dataset;
                                    selected: AppState.selected-dataset-id == dataset.dataset-id;
                                    activated(id) => { Logic.select-dataset(id); }
                                }
                            }
                        }
                    }
                }

                Panel {
                    title: "状态摘要";
                    subtitle: "";
                    min-height: 188px;

                    SummaryLine {
                        label: "当前集";
                        value: AppState.current-dataset-name;
                    }

                    SummaryLine {
                        label: "概况";
                        value: AppState.current-dataset-overview;
                    }

                    SummaryLine {
                        label: "质量";
                        value: AppState.quality-summary;
                    }

                    SummaryLine {
                        label: "状态";
                        value: AppState.status-message;
                    }
                }
            }

            VerticalBox {
                horizontal-stretch: 1;
                min-width: 0px;
                height: parent.height;
                spacing: root.page-padding;
                padding-bottom: 10px;

                if AppState.selected-dataset-id != 0: HorizontalBox {
                    spacing: 6px;
                    for metric in AppState.metrics: MetricTile {
                        metric: metric;
                    }
                }

                Panel {
                    title: "工作区";
                    subtitle: "";
                    horizontal-stretch: 1;
                    vertical-stretch: 1;

                    HorizontalBox {
                        spacing: 4px;

                        TabButton {
                            label: "数据预览与台账";
                            selected: root.active-tab == 0;
                            pressed => { root.active-tab = 0; }
                        }

                        TabButton {
                            label: "数据质量检查";
                            
                            selected: root.active-tab == 1;
                            pressed => { root.active-tab = 1; }
                        }

                        TabButton {
                            label: "数据清洗处理";
                            selected: root.active-tab == 2;
                            pressed => { root.active-tab = 2; }
                        }

                        TabButton {
                            label: "字段派生与排序";
                            selected: root.active-tab == 3;
                            pressed => { root.active-tab = 3; }
                        }

                        TabButton {
                            label: "多表关联融合";
                            selected: root.active-tab == 4;
                            pressed => { root.active-tab = 4; }
                        }

                        TabButton {
                            label: "处理流程记录";
                            selected: root.active-tab == 5;
                            pressed => { root.active-tab = 5; }
                        }
                    }

                    Rectangle {
                        horizontal-stretch: 1;
                        vertical-stretch: 1;
                        background: transparent;
                        min-width: 0px;
                        min-height: 0px;
                        clip: false;

                        Rectangle {
                            x: 2px;
                            y: 2px;
                            width: parent.width > 4px ? parent.width - 4px : 0px;
                            height: parent.height > 4px ? parent.height - 4px : 0px;
                            background: transparent;
                            min-width: 0px;
                            min-height: 0px;
                            clip: false;

                            preview-page := Rectangle {
                                visible: root.active-tab == 0;
                                x: 0px;
                                y: 0px;
                                width: parent.width;
                                height: parent.height;
                                background: transparent;
                                clip: true;

                                preview-page-scroll := ScrollView {
                                    x: 0px;
                                    y: 0px;
                                    width: parent.width;
                                    height: parent.height;
                                    horizontal-scrollbar-policy: ScrollBarPolicy.always-off;
                                    viewport-width: self.visible-width;
                                    viewport-height: preview-page-content.preferred-height;

                                    preview-page-content := VerticalBox {
                                        width: preview-page-scroll.visible-width;
                                        spacing: 8px;

                                        Panel {
                                            title: "样表预览";
                                            subtitle: "";
                                            horizontal-stretch: 1;
                                            vertical-stretch: 3;

                                            VerticalBox {
                                                spacing: 6px;

                                                HorizontalBox {
                                                    spacing: 6px;

                                                    LabeledChoice {
                                                        width: 140px;
                                                        label: "模式";
                                                        model: ["分页", "随机抽样"];
                                                        value <=> FormState.preview-mode;
                                                    }

                                                    LabeledField {
                                                        width: 96px;
                                                        label: "每页行数";
                                                        placeholder: "20";
                                                        text <=> FormState.preview-row-count;
                                                    }

                                                    InlineActionButton {
                                                        width: 86px;
                                                        label: "应用";
                                                        primary: true;
                                                        pressed => { Logic.apply-preview-settings(); }
                                                    }

                                                    Rectangle {
                                                        horizontal-stretch: 1;
                                                    }

                                                    Text {
                                                        width: 150px;
                                                        vertical-alignment: center;
                                                        color: AppTheme.text-soft;
                                                        font-size: 10px;
                                                        text: AppState.preview-range-label;
                                                        horizontal-alignment: right;
                                                    }

                                                    HorizontalBox {
                                                        width: 286px;
                                                        spacing: 6px;

                                                        Button {
                                                            text: "上一页";
                                                            height: 28px;
                                                            enabled: AppState.can-preview-prev;
                                                            clicked => { Logic.preview-prev-page(); }
                                                        }

                                                        PagerBadge {
                                                            label: AppState.preview-page-label;
                                                        }

                                                        Button {
                                                            text: "下一页";
                                                            height: 28px;
                                                            enabled: AppState.can-preview-next;
                                                            clicked => { Logic.preview-next-page(); }
                                                        }
                                                    }
                                                }

                                                Rectangle {
                                                    min-height: 360px;
                                                    vertical-stretch: 1;
                                                    background: AppTheme.panel-bg;
                                                    border-width: 1px;
                                                    border-color: AppTheme.border;
                                                    clip: true;

                                                    preview-scroll := ScrollView {
                                                        x: 0px;
                                                        y: 0px;
                                                        width: parent.width;
                                                        height: parent.height;
                                                        viewport-width: max(self.visible-width, preview-content.preferred-width + root.preview-scroll-gutter);
                                                        viewport-height: max(self.visible-height, preview-content.preferred-height);
                                                        preview-table := Rectangle {
                                                            width: preview-scroll.viewport-width;
                                                            height: preview-scroll.viewport-height;
                                                            background: AppTheme.panel-bg;

                                                            preview-content := VerticalBox {
                                                                width: root.preview-table-width;
                                                                spacing: 0px;

                                                                HorizontalBox {
                                                                    spacing: 0px;
                                                                    LedgerHeaderCell {
                                                                        cell-width: 54px;
                                                                        label: "#";
                                                                        center: true;
                                                                    }

                                                                    for header in AppState.preview-columns: LedgerHeaderCell {
                                                                        cell-width: root.preview-col-width;
                                                                        label: header;
                                                                    }
                                                                }

                                                                for row[index] in AppState.preview-rows: HorizontalBox {
                                                                    spacing: 0px;
                                                                    LedgerCell {
                                                                        cell-width: 54px;
                                                                        value: row.row-label;
                                                                        alternate: Math.mod(index, 2) == 1;
                                                                        center: true;
                                                                    }

                                                                    for cell in row.cells: LedgerCell {
                                                                        cell-width: root.preview-col-width;
                                                                        value: cell;
                                                                        alternate: Math.mod(index, 2) == 1;
                                                                    }
                                                                }
                                                            }
                                                        }
                                                    }
                                                }
                                            }
                                        }

                                        Panel {
                                            title: "字段台账";
                                            subtitle: "";
                                            horizontal-stretch: 1;
                                            vertical-stretch: 3;

                                            VerticalBox {
                                                spacing: 6px;

                                                HorizontalBox {
                                                    spacing: 6px;

                                                    LabeledField {
                                                        width: 96px;
                                                        label: "每页字段";
                                                        placeholder: "12";
                                                        text <=> FormState.field-row-count;
                                                    }

                                                    InlineActionButton {
                                                        width: 86px;
                                                        label: "应用";
                                                        pressed => { Logic.apply-field-settings(); }
                                                    }

                                                    Rectangle {
                                                        horizontal-stretch: 1;
                                                    }

                                                    Text {
                                                        width: 150px;
                                                        vertical-alignment: center;
                                                        color: AppTheme.text-soft;
                                                        font-size: 10px;
                                                        text: AppState.field-range-label;
                                                        horizontal-alignment: right;
                                                    }

                                                    HorizontalBox {
                                                        width: 286px;
                                                        spacing: 6px;

                                                        Button {
                                                            text: "上一页";
                                                            height: 28px;
                                                            enabled: AppState.can-field-prev;
                                                            clicked => { Logic.field-prev-page(); }
                                                        }

                                                        PagerBadge {
                                                            label: AppState.field-page-label;
                                                        }

                                                        Button {
                                                            text: "下一页";
                                                            height: 28px;
                                                            enabled: AppState.can-field-next;
                                                            clicked => { Logic.field-next-page(); }
                                                        }
                                                    }
                                                }

                                                Rectangle {
                                                    min-height: max(240px, 28px + AppState.field-page-size * 28px + root.table-scrollbar-gutter);
                                                    vertical-stretch: 1;
                                                    background: AppTheme.panel-bg;
                                                    border-width: 1px;
                                                    border-color: AppTheme.border;
                                                    clip: true;

                                                    field-scroll := ScrollView {
                                                        x: 0px;
                                                        y: 0px;
                                                        width: parent.width;
                                                        height: parent.height;
                                                        viewport-width: max(self.visible-width, root.field-table-width);
                                                        viewport-height: max(self.visible-height, field-content.preferred-height);
                                                        field-table := Rectangle {
                                                            width: field-scroll.viewport-width;
                                                            height: field-scroll.viewport-height;
                                                            background: AppTheme.panel-bg;

                                                            field-content := VerticalBox {
                                                                width: parent.width;
                                                                spacing: 0px;

                                                                HorizontalBox {
                                                                    spacing: 0px;
                                                                    LedgerHeaderCell {
                                                                        cell-width: 180px;
                                                                        label: "字段";
                                                                    }

                                                                    LedgerHeaderCell {
                                                                        cell-width: 80px;
                                                                        label: "类型";
                                                                    }

                                                                    LedgerHeaderCell {
                                                                        cell-width: 80px;
                                                                        label: "非空";
                                                                        center: true;
                                                                    }

                                                                    LedgerHeaderCell {
                                                                        cell-width: 80px;
                                                                        label: "缺失";
                                                                        center: true;
                                                                    }

                                                                    LedgerHeaderCell {
                                                                        cell-width: 92px;
                                                                        label: "缺失率";
                                                                        center: true;
                                                                    }

                                                                    LedgerHeaderCell {
                                                                        cell-width: 80px;
                                                                        label: "唯一值";
                                                                        center: true;
                                                                    }

                                                                    LedgerHeaderCell {
                                                                        cell-width: 220px;
                                                                        label: "示例";
                                                                    }
                                                                }

                                                                for column[index] in AppState.columns: HorizontalBox {
                                                                    spacing: 0px;
                                                                    LedgerCell {
                                                                        cell-width: 180px;
                                                                        value: column.name;
                                                                        alternate: Math.mod(index, 2) == 1;
                                                                    }

                                                                    LedgerCell {
                                                                        cell-width: 80px;
                                                                        value: column.dtype;
                                                                        alternate: Math.mod(index, 2) == 1;
                                                                    }

                                                                    LedgerCell {
                                                                        cell-width: 80px;
                                                                        value: column.non-null;
                                                                        alternate: Math.mod(index, 2) == 1;
                                                                        center: true;
                                                                    }

                                                                    LedgerCell {
                                                                        cell-width: 80px;
                                                                        value: column.missing-count;
                                                                        alternate: Math.mod(index, 2) == 1;
                                                                        center: true;
                                                                    }

                                                                    LedgerCell {
                                                                        cell-width: 92px;
                                                                        value: column.missing-rate;
                                                                        alternate: Math.mod(index, 2) == 1;
                                                                        center: true;
                                                                    }

                                                                    LedgerCell {
                                                                        cell-width: 80px;
                                                                        value: column.unique-count;
                                                                        alternate: Math.mod(index, 2) == 1;
                                                                        center: true;
                                                                    }

                                                                    LedgerCell {
                                                                        cell-width: 220px;
                                                                        value: column.sample-value;
                                                                        alternate: Math.mod(index, 2) == 1;
                                                                    }
                                                                }

                                                                Rectangle {
                                                                    height: root.table-scrollbar-gutter;
                                                                    background: transparent;
                                                                }
                                                            }
                                                        }
                                                    }
                                                }
                                            }
                                        }
                                    }
                                }
                            }

                            quality-page := Rectangle {
                                visible: root.active-tab == 1;
                                x: 0px;
                                y: 0px;
                                width: parent.width;
                                height: parent.height;
                                background: transparent;
                                clip: true;

                                VerticalBox {
                                    horizontal-stretch: 1;
                                    vertical-stretch: 1;
                                    min-width: 0px;
                                    min-height: 0px;
                                    spacing: 8px;

                                    Rectangle {
                                        min-height: 44px;
                                        max-height: 44px;
                                        horizontal-stretch: 1;
                                        background: AppTheme.panel-bg;
                                        border-width: 1px;
                                        border-color: AppTheme.border;

                                        HorizontalBox {
                                            width: parent.width;
                                            height: parent.height;
                                            padding-left: 8px;
                                            padding-right: 8px;
                                            spacing: 6px;

                                            Button {
                                                text: "重新复检";
                                                primary: true;
                                                height: 28px;
                                                clicked => { Logic.refresh-current(); }
                                            }

                                            Button {
                                                text: "导出 PDF";
                                                height: 28px;
                                                clicked => { Logic.export-quality-report(); }
                                            }
                                        }
                                    }

                                    Panel {
                                        title: "质量规则";
                                        subtitle: AppState.quality-rule-summary;
                                        horizontal-stretch: 1;

                                        VerticalBox {
                                            spacing: 6px;

                                            HorizontalBox {
                                                spacing: 6px;

                                                LabeledField {
                                                    width: 150px;
                                                    label: "主键";
                                                    placeholder: "如 id";
                                                    text <=> FormState.quality-primary-key;
                                                }

                                                LabeledField {
                                                    width: 250px;
                                                    label: "组合键";
                                                    placeholder: "逗号分隔，如 batch_id, device_id";
                                                    text <=> FormState.quality-composite-keys;
                                                }

                                                LabeledField {
                                                    width: 150px;
                                                    label: "时间列";
                                                    placeholder: "如 created_at";
                                                    text <=> FormState.quality-time-column;
                                                }

                                                LabeledField {
                                                    width: 120px;
                                                    label: "高缺失阈值(%)";
                                                    placeholder: "5 - 95";
                                                    text <=> FormState.quality-missing-threshold;
                                                }

                                                Rectangle {
                                                    horizontal-stretch: 1;
                                                    min-width: 0px;
                                                }
                                            }

                                            HorizontalBox {
                                                spacing: 6px;

                                                LabeledField {
                                                    width: 160px;
                                                    label: "数值列";
                                                    placeholder: "如 temperature";
                                                    text <=> FormState.quality-range-column;
                                                }

                                                LabeledField {
                                                    width: 100px;
                                                    label: "最小值";
                                                    placeholder: "可留空";
                                                    text <=> FormState.quality-range-min;
                                                }

                                                LabeledField {
                                                    width: 100px;
                                                    label: "最大值";
                                                    placeholder: "可留空";
                                                    text <=> FormState.quality-range-max;
                                                }

                                                LabeledField {
                                                    width: 160px;
                                                    label: "文本列";
                                                    placeholder: "如 device_name";
                                                    text <=> FormState.quality-text-column;
                                                }

                                                LabeledField {
                                                    width: 110px;
                                                    label: "最大长度";
                                                    placeholder: "字符数";
                                                    text <=> FormState.quality-max-length;
                                                }

                                                LabeledField {
                                                    width: 130px;
                                                    label: "时间间隔(分钟)";
                                                    placeholder: "如 60";
                                                    text <=> FormState.quality-time-gap-minutes;
                                                }

                                                Rectangle {
                                                    horizontal-stretch: 1;
                                                    min-width: 0px;
                                                }

                                                Rectangle {
                                                    width: 110px;
                                                    height: 48px;
                                                    background: transparent;

                                                    Button {
                                                        y: 20px;
                                                        width: parent.width;
                                                        height: 28px;
                                                        text: "应用规则";
                                                        primary: true;
                                                        clicked => { Logic.apply-quality-rules(); }
                                                    }
                                                }
                                            }
                                        }
                                    }

                                    Panel {
                                        title: "问题台账";
                                        subtitle: AppState.quality-summary;
                                        horizontal-stretch: 1;
                                        vertical-stretch: 1;

                                        Rectangle {
                                            min-height: 320px;
                                            vertical-stretch: 1;
                                            background: AppTheme.panel-bg;
                                            border-width: 1px;
                                            border-color: AppTheme.border;
                                            clip: true;

                                            ScrollView {
                                                x: 0px;
                                                y: 0px;
                                                width: parent.width;
                                                height: parent.height;
                                                viewport-width: max(self.visible-width, root.issue-table-width);
                                                viewport-height: max(self.visible-height, issue-content.preferred-height);
                                                issue-table := Rectangle {
                                                    width: parent.viewport-width;
                                                    height: parent.viewport-height;
                                                    background: AppTheme.panel-bg;

                                                    issue-content := VerticalBox {
                                                        width: parent.width;
                                                        spacing: 0px;

                                                        HorizontalBox {
                                                            spacing: 0px;
                                                            LedgerHeaderCell {
                                                                cell-width: 96px;
                                                                label: "类别";
                                                            }

                                                            LedgerHeaderCell {
                                                                cell-width: 64px;
                                                                label: "等级";
                                                                center: true;
                                                            }

                                                            LedgerHeaderCell {
                                                                cell-width: 180px;
                                                                label: "字段";
                                                            }

                                                            LedgerHeaderCell {
                                                                cell-width: 620px;
                                                                label: "说明";
                                                            }
                                                        }

                                                        for issue in AppState.issues: IssueRow {
                                                            category: issue.category;
                                                            severity: issue.severity;
                                                            field: issue.field;
                                                            detail: issue.detail;
                                                        }
                                                    }
                                                }
                                            }
                                        }
                                    }
                                }
                            }

                            cleaning-page := Rectangle {
                                visible: root.active-tab == 2;
                                x: 0px;
                                y: 0px;
                                width: parent.width;
                                height: parent.height;
                                background: transparent;
                                clip: true;

                                cleaning-page-scroll := ScrollView {
                                    x: 0px;
                                    y: 0px;
                                    width: parent.width;
                                    height: parent.height;
                                    horizontal-scrollbar-policy: ScrollBarPolicy.always-off;
                                    vertical-scrollbar-policy: ScrollBarPolicy.always-on;
                                    viewport-width: self.visible-width;
                                    viewport-height: max(self.visible-height, root.cleaning-content-height);

                                    cleaning-scroll-body := Rectangle {
                                        width: cleaning-page-scroll.visible-width;
                                        height: root.cleaning-content-height;
                                        background: transparent;

                                        cleaning-scroll-content := VerticalBox {
                                            width: parent.width;
                                            height: parent.height;
                                            spacing: root.cleaning-panel-gap;

                                            Panel {
                                                title: "行处理";
                                                subtitle: "";
                                                horizontal-stretch: 1;
                                                height: 148px;

                                                VerticalBox {
                                                    spacing: 6px;

                                                    HorizontalBox {
                                                        spacing: 6px;

                                                        LabeledChoice {
                                                            width: 180px;
                                                            label: "动作";
                                                            model: [
                                                                "删除空行",
                                                                "整表去重",
                                                                "按列去重",
                                                                "按关键词保留",
                                                                "按关键词删除",
                                                                "保留缺失记录",
                                                                "保留行范围",
                                                                "删除行范围",
                                                                "保留前N行",
                                                                "抽样N行",
                                                                "删除缺失记录"
                                                            ];
                                                            value <=> FormState.row-operation;
                                                        }

                                                        if FormState.row-operation == "按列去重": LabeledField {
                                                            width: 220px;
                                                            label: "去重字段";
                                                            placeholder: "device_id,timestamp";
                                                            text <=> FormState.row-key-columns;
                                                        }

                                                        if FormState.row-operation == "按关键词保留" || FormState.row-operation == "按关键词删除": LabeledField {
                                                            width: 150px;
                                                            label: "筛选列";
                                                            placeholder: "status";
                                                            text <=> FormState.filter-column;
                                                        }

                                                        if FormState.row-operation == "按关键词保留" || FormState.row-operation == "按关键词删除": LabeledField {
                                                            width: 160px;
                                                            label: "关键词";
                                                            placeholder: "offline";
                                                            text <=> FormState.filter-keyword;
                                                        }

                                                        if FormState.row-operation == "保留行范围" || FormState.row-operation == "删除行范围": LabeledField {
                                                            width: 96px;
                                                            label: "起始";
                                                            placeholder: "1";
                                                            text <=> FormState.range-start;
                                                        }

                                                        if FormState.row-operation == "保留行范围" || FormState.row-operation == "删除行范围": LabeledField {
                                                            width: 96px;
                                                            label: "结束";
                                                            placeholder: "100";
                                                            text <=> FormState.range-end;
                                                        }

                                                        if FormState.row-operation == "保留前N行": LabeledField {
                                                            width: 110px;
                                                            label: "行数";
                                                            placeholder: "100";
                                                            text <=> FormState.top-row-count;
                                                        }

                                                        if FormState.row-operation == "抽样N行": LabeledField {
                                                            width: 110px;
                                                            label: "样本数";
                                                            placeholder: "50";
                                                            text <=> FormState.sample-row-count;
                                                        }

                                                        if FormState.row-operation == "保留缺失记录" || FormState.row-operation == "删除缺失记录": LabeledField {
                                                            width: 260px;
                                                            label: "检查列";
                                                            placeholder: "device_id,status";
                                                            text <=> FormState.missing-columns;
                                                        }

                                                        Rectangle {
                                                            horizontal-stretch: 1;
                                                            min-width: 0px;
                                                        }

                                                        InlineActionButton {
                                                            width: 88px;
                                                            label: "执行";
                                                            primary: true;
                                                            pressed => { Logic.apply-row-operation(); }
                                                        }
                                                    }
                                                }
                                            }

                                            Panel {
                                                title: "列处理";
                                                subtitle: "";
                                                horizontal-stretch: 1;
                                                height: 168px;

                                                HorizontalBox {
                                                    spacing: 6px;

                                                    LabeledChoice {
                                                        width: 180px;
                                                        label: "动作";
                                                        model: [
                                                            "列名标准化",
                                                            "重命名列",
                                                            "保留列",
                                                            "删除列",
                                                            "删除空列",
                                                            "调整列顺序",
                                                            "列名前缀",
                                                            "列名后缀",
                                                            "复制列",
                                                            "合并列",
                                                            "新增序号列",
                                                            "按列排序"
                                                        ];
                                                        value <=> FormState.column-operation;
                                                    }

                                                    if FormState.column-operation == "重命名列": LabeledField {
                                                        width: 180px;
                                                        label: "原列名";
                                                        placeholder: "source_col";
                                                        text <=> FormState.rename-from;
                                                    }

                                                    if FormState.column-operation == "重命名列": LabeledField {
                                                        width: 180px;
                                                        label: "新列名";
                                                        placeholder: "target_col";
                                                        text <=> FormState.rename-to;
                                                    }

                                                    if FormState.column-operation == "保留列" || FormState.column-operation == "删除列": LabeledField {
                                                        horizontal-stretch: 1;
                                                        label: "列清单";
                                                        placeholder: "a,b,c";
                                                        text <=> FormState.column-list;
                                                    }

                                                    if FormState.column-operation == "列名前缀": LabeledField {
                                                        width: 180px;
                                                        label: "前缀";
                                                        placeholder: "src_";
                                                        text <=> FormState.column-name-prefix;
                                                    }

                                                    if FormState.column-operation == "列名后缀": LabeledField {
                                                        width: 180px;
                                                        label: "后缀";
                                                        placeholder: "_std";
                                                        text <=> FormState.column-name-suffix;
                                                    }

                                                    if FormState.column-operation == "调整列顺序": LabeledField {
                                                        horizontal-stretch: 1;
                                                        label: "排序后的列顺序";
                                                        placeholder: "timestamp,device_id,status";
                                                        text <=> FormState.column-order-list;
                                                    }

                                                    if FormState.column-operation == "复制列": LabeledField {
                                                        width: 180px;
                                                        label: "来源列";
                                                        placeholder: "device_id";
                                                        text <=> FormState.copy-source-column;
                                                    }

                                                    if FormState.column-operation == "复制列": LabeledField {
                                                        width: 180px;
                                                        label: "新列名";
                                                        placeholder: "device_id_copy";
                                                        text <=> FormState.copy-target-column;
                                                    }

                                                    if FormState.column-operation == "合并列": LabeledField {
                                                        width: 240px;
                                                        label: "来源列";
                                                        placeholder: "province,city";
                                                        text <=> FormState.merge-columns;
                                                    }

                                                    if FormState.column-operation == "合并列": LabeledField {
                                                        width: 180px;
                                                        label: "目标列";
                                                        placeholder: "location";
                                                        text <=> FormState.merge-target-column;
                                                    }

                                                    if FormState.column-operation == "合并列": LabeledField {
                                                        width: 96px;
                                                        label: "分隔符";
                                                        placeholder: "_";
                                                        text <=> FormState.merge-separator;
                                                    }

                                                    if FormState.column-operation == "新增序号列": LabeledField {
                                                        width: 180px;
                                                        label: "列名";
                                                        placeholder: "row_no";
                                                        text <=> FormState.index-column-name;
                                                    }

                                                    if FormState.column-operation == "新增序号列": LabeledField {
                                                        width: 96px;
                                                        label: "起始值";
                                                        placeholder: "1";
                                                        text <=> FormState.index-start;
                                                    }

                                                    if FormState.column-operation == "按列排序": LabeledField {
                                                        width: 180px;
                                                        label: "排序列";
                                                        placeholder: "timestamp";
                                                        text <=> FormState.sort-column;
                                                    }

                                                    if FormState.column-operation == "按列排序": InlineToggleButton {
                                                        width: 88px;
                                                        label: FormState.sort-ascending ? "升序" : "降序";
                                                        checked <=> FormState.sort-ascending;
                                                    }

                                                    Rectangle {
                                                        horizontal-stretch: 1;
                                                        min-width: 0px;
                                                    }

                                                    InlineActionButton {
                                                        width: 88px;
                                                        label: "执行";
                                                        primary: true;
                                                        pressed => { Logic.apply-column-operation(); }
                                                    }
                                                }
                                            }

                                            Panel {
                                                title: "文本处理";
                                                subtitle: "";
                                                horizontal-stretch: 1;
                                                height: 148px;

                                                HorizontalBox {
                                                    spacing: 6px;

                                                    LabeledChoice {
                                                        width: 180px;
                                                        label: "动作";
                                                        model: [
                                                            "文本去空白",
                                                            "压缩空白",
                                                            "大小写统一",
                                                            "文本替换",
                                                            "移除指定字符",
                                                            "提取分隔符左侧",
                                                            "提取分隔符右侧",
                                                            "仅保留数字",
                                                            "添加前后缀",
                                                            "文本截断"
                                                        ];
                                                        value <=> FormState.text-operation;
                                                    }

                                                    if FormState.text-operation != "文本去空白": LabeledField {
                                                        width: 180px;
                                                        label: "目标列";
                                                        placeholder: "status";
                                                        text <=> FormState.text-column;
                                                    }

                                                    if FormState.text-operation == "大小写统一": LabeledChoice {
                                                        width: 140px;
                                                        label: "大小写";
                                                        model: ["upper", "lower"];
                                                        value <=> FormState.text-case;
                                                    }

                                                    if FormState.text-operation == "文本替换": LabeledField {
                                                        width: 140px;
                                                        label: "替换前";
                                                        placeholder: "FAIL";
                                                        text <=> FormState.replace-from;
                                                    }

                                                    if FormState.text-operation == "文本替换": LabeledField {
                                                        width: 140px;
                                                        label: "替换后";
                                                        placeholder: "FAILED";
                                                        text <=> FormState.replace-to;
                                                    }

                                                    if FormState.text-operation == "移除指定字符": LabeledField {
                                                        width: 160px;
                                                        label: "移除内容";
                                                        placeholder: "-";
                                                        text <=> FormState.text-remove-pattern;
                                                    }

                                                    if FormState.text-operation == "提取分隔符左侧" || FormState.text-operation == "提取分隔符右侧": LabeledField {
                                                        width: 120px;
                                                        label: "分隔符";
                                                        placeholder: "_";
                                                        text <=> FormState.text-delimiter;
                                                    }

                                                    if FormState.text-operation == "添加前后缀": LabeledField {
                                                        width: 120px;
                                                        label: "前缀";
                                                        placeholder: "DEV-";
                                                        text <=> FormState.text-prefix;
                                                    }

                                                    if FormState.text-operation == "添加前后缀": LabeledField {
                                                        width: 120px;
                                                        label: "后缀";
                                                        placeholder: "-A";
                                                        text <=> FormState.text-suffix;
                                                    }

                                                    if FormState.text-operation == "文本截断": LabeledField {
                                                        width: 96px;
                                                        label: "长度";
                                                        placeholder: "32";
                                                        text <=> FormState.text-truncate-length;
                                                    }

                                                    Rectangle {
                                                        horizontal-stretch: 1;
                                                        min-width: 0px;
                                                    }

                                                    InlineActionButton {
                                                        width: 88px;
                                                        label: "执行";
                                                        primary: true;
                                                        pressed => { Logic.apply-text-operation(); }
                                                    }
                                                }
                                            }

                                            Panel {
                                                title: "值处理";
                                                subtitle: "";
                                                horizontal-stretch: 1;
                                                height: 178px;

                                                HorizontalBox {
                                                    spacing: 6px;

                                                    LabeledChoice {
                                                        width: 180px;
                                                        label: "动作";
                                                        model: [
                                                            "默认值填充",
                                                            "前值填充",
                                                            "后值填充",
                                                            "统计值填充",
                                                            "空字符串转空值",
                                                            "零值转空值",
                                                            "指定值替换",
                                                            "字符串转数值",
                                                            "字符串转日期",
                                                            "整型转浮点",
                                                            "布尔值转换",
                                                            "类型转换",
                                                            "数值保留小数位",
                                                            "数值乘系数",
                                                            "数值加偏移",
                                                            "数值裁剪"
                                                        ];
                                                        value <=> FormState.value-operation;
                                                    }

                                                    if FormState.value-operation == "默认值填充" || FormState.value-operation == "前值填充" || FormState.value-operation == "后值填充" || FormState.value-operation == "空字符串转空值" || FormState.value-operation == "零值转空值": LabeledField {
                                                        width: 180px;
                                                        label: "目标列";
                                                        placeholder: "status";
                                                        text <=> FormState.fill-column;
                                                    }

                                                    if FormState.value-operation == "统计值填充": LabeledField {
                                                        width: 180px;
                                                        label: "目标列";
                                                        placeholder: "temperature";
                                                        text <=> FormState.stat-fill-column;
                                                    }

                                                    if FormState.value-operation == "统计值填充": LabeledChoice {
                                                        width: 120px;
                                                        label: "统计方式";
                                                        model: ["均值", "中位数", "众数"];
                                                        value <=> FormState.stat-fill-strategy;
                                                    }

                                                    if FormState.value-operation == "指定值替换": LabeledField {
                                                        width: 160px;
                                                        label: "目标列";
                                                        placeholder: "status";
                                                        text <=> FormState.value-replace-column;
                                                    }

                                                    if FormState.value-operation == "指定值替换": LabeledField {
                                                        width: 120px;
                                                        label: "原值";
                                                        placeholder: "N/A";
                                                        text <=> FormState.value-replace-from;
                                                    }

                                                    if FormState.value-operation == "指定值替换": LabeledField {
                                                        width: 120px;
                                                        label: "新值";
                                                        placeholder: "offline";
                                                        text <=> FormState.value-replace-to;
                                                    }

                                                    if FormState.value-operation == "默认值填充": LabeledField {
                                                        width: 180px;
                                                        label: "默认值";
                                                        placeholder: "offline";
                                                        text <=> FormState.fill-value;
                                                    }

                                                    if FormState.value-operation == "类型转换" || FormState.value-operation == "字符串转数值" || FormState.value-operation == "字符串转日期" || FormState.value-operation == "整型转浮点": LabeledField {
                                                        width: 180px;
                                                        label: "转换列";
                                                        placeholder: "value";
                                                        text <=> FormState.cast-column;
                                                    }

                                                    if FormState.value-operation == "类型转换": LabeledChoice {
                                                        width: 140px;
                                                        label: "目标类型";
                                                        model: ["text", "int", "float", "bool", "time"];
                                                        value <=> FormState.cast-target;
                                                    }

                                                    if FormState.value-operation == "布尔值转换": LabeledField {
                                                        width: 180px;
                                                        label: "布尔列";
                                                        placeholder: "is_active";
                                                        text <=> FormState.bool-convert-column;
                                                    }

                                                    if FormState.value-operation == "数值保留小数位" || FormState.value-operation == "数值乘系数" || FormState.value-operation == "数值加偏移" || FormState.value-operation == "数值裁剪": LabeledField {
                                                        width: 180px;
                                                        label: "数值列";
                                                        placeholder: "temperature";
                                                        text <=> FormState.round-column;
                                                    }

                                                    if FormState.value-operation == "数值保留小数位": LabeledField {
                                                        width: 96px;
                                                        label: "位数";
                                                        placeholder: "2";
                                                        text <=> FormState.round-digits;
                                                    }

                                                    if FormState.value-operation == "数值乘系数": LabeledField {
                                                        width: 96px;
                                                        label: "系数";
                                                        placeholder: "1.5";
                                                        text <=> FormState.numeric-scale-factor;
                                                    }

                                                    if FormState.value-operation == "数值加偏移": LabeledField {
                                                        width: 96px;
                                                        label: "偏移";
                                                        placeholder: "-10";
                                                        text <=> FormState.numeric-offset;
                                                    }

                                                    if FormState.value-operation == "数值裁剪": LabeledField {
                                                        width: 96px;
                                                        label: "最小值";
                                                        placeholder: "0";
                                                        text <=> FormState.numeric-clamp-min;
                                                    }

                                                    if FormState.value-operation == "数值裁剪": LabeledField {
                                                        width: 96px;
                                                        label: "最大值";
                                                        placeholder: "100";
                                                        text <=> FormState.numeric-clamp-max;
                                                    }

                                                    Rectangle {
                                                        horizontal-stretch: 1;
                                                        min-width: 0px;
                                                    }

                                                    InlineActionButton {
                                                        width: 88px;
                                                        label: "执行";
                                                        primary: true;
                                                        pressed => { Logic.apply-value-operation(); }
                                                    }
                                                }
                                            }

                                            Panel {
                                                title: "时间处理";
                                                subtitle: "";
                                                horizontal-stretch: 1;
                                                height: 190px;

                                                VerticalBox {
                                                    spacing: 6px;

                                                    HorizontalBox {
                                                        spacing: 6px;

                                                        LabeledChoice {
                                                            width: 180px;
                                                            label: "动作";
                                                            model: [
                                                                "时间格式统一",
                                                                "时间戳转换",
                                                                "日期拆分",
                                                                "年",
                                                                "月",
                                                                "日",
                                                                "时",
                                                                "时间窗口筛选",
                                                                "时间排序",
                                                                "时间格式标准化",
                                                                "时间偏移(分钟)",
                                                                "提取日期列",
                                                                "提取小时列"
                                                            ];
                                                            value <=> FormState.time-operation;
                                                        }

                                                        LabeledField {
                                                            width: 180px;
                                                            label: "目标列";
                                                            placeholder: "event_time";
                                                            text <=> FormState.time-target-column;
                                                        }

                                                        Rectangle {
                                                            horizontal-stretch: 1;
                                                            min-width: 0px;
                                                        }

                                                        InlineActionButton {
                                                            width: 88px;
                                                            label: "执行";
                                                            primary: true;
                                                            pressed => { Logic.apply-time-operation(); }
                                                        }
                                                    }

                                                    HorizontalBox {
                                                        spacing: 6px;

                                                        if FormState.time-operation == "时间偏移(分钟)": LabeledField {
                                                            width: 110px;
                                                            label: "偏移分钟";
                                                            placeholder: "60";
                                                            text <=> FormState.time-shift-minutes;
                                                        }

                                                        if FormState.time-operation == "提取日期列" || FormState.time-operation == "提取小时列" || FormState.time-operation == "年" || FormState.time-operation == "月" || FormState.time-operation == "日" || FormState.time-operation == "时": LabeledField {
                                                            width: 160px;
                                                            label: "输出列";
                                                            placeholder: "event_date";
                                                            text <=> FormState.time-output-column;
                                                        }

                                                        if FormState.time-operation == "日期拆分": LabeledField {
                                                            width: 180px;
                                                            label: "输出前缀";
                                                            placeholder: "event";
                                                            text <=> FormState.time-output-prefix;
                                                        }

                                                        if FormState.time-operation == "时间窗口筛选": LabeledField {
                                                            width: 180px;
                                                            label: "开始时间";
                                                            placeholder: "2024-01-01 00:00:00";
                                                            text <=> FormState.time-window-start;
                                                        }

                                                        if FormState.time-operation == "时间窗口筛选": LabeledField {
                                                            width: 180px;
                                                            label: "结束时间";
                                                            placeholder: "2024-01-31 23:59:59";
                                                            text <=> FormState.time-window-end;
                                                        }

                                                        if FormState.time-operation == "时间排序": InlineToggleButton {
                                                            width: 88px;
                                                            label: FormState.time-sort-ascending ? "升序" : "降序";
                                                            checked <=> FormState.time-sort-ascending;
                                                        }

                                                        Rectangle {
                                                            horizontal-stretch: 1;
                                                            min-width: 0px;
                                                        }
                                                    }
                                                }
                                            }

                                            Rectangle {
                                                height: root.cleaning-bottom-padding;
                                                background: transparent;
                                            }
                                        }
                                    }
                                }
                            }

                            aggregate-page := Rectangle {
                                visible: root.active-tab == 3;
                                x: 0px;
                                y: 0px;
                                width: parent.width;
                                height: parent.height;
                                background: transparent;
                                clip: true;

                                VerticalBox {
                                    horizontal-stretch: 1;
                                    vertical-stretch: 1;
                                    min-width: 0px;
                                    min-height: 0px;
                                    spacing: 8px;

                                    Panel {
                                        title: "分组与聚合";
                                        subtitle: "";
                                        horizontal-stretch: 1;

                                        VerticalBox {
                                            spacing: 6px;

                                            HorizontalBox {
                                                spacing: 6px;

                                                LabeledField {
                                                    width: 260px;
                                                    label: "分组字段";
                                                    placeholder: "device_id,status";
                                                    text <=> FormState.aggregate-group-columns;
                                                }

                                                LabeledChoice {
                                                    width: 140px;
                                                    label: "聚合方式";
                                                    model: ["计数", "去重计数", "求和", "平均值", "最大值", "最小值"];
                                                    value <=> FormState.aggregate-function;
                                                }

                                                InlineActionButton {
                                                    width: 88px;
                                                    label: "执行";
                                                    primary: true;
                                                    pressed => { Logic.apply-group-aggregate(); }
                                                }
                                            }

                                            HorizontalBox {
                                                spacing: 6px;

                                                LabeledField {
                                                    width: 260px;
                                                    label: "目标字段";
                                                    placeholder: "value";
                                                    text <=> FormState.aggregate-target-column;
                                                }

                                                Text {
                                                    vertical-alignment: center;
                                                    color: AppTheme.text-soft;
                                                    font-size: 10px;
                                                    text: "计数可留空，其余聚合建议填写数值列。";
                                                }
                                            }
                                        }
                                    }

                                    Rectangle {
                                        vertical-stretch: 1;
                                        background: transparent;
                                    }
                                }
                            }

                            derive-page := Rectangle {
                                visible: root.active-tab == 3;
                                x: 0px;
                                y: 0px;
                                width: parent.width;
                                height: parent.height;
                                background: AppTheme.window-bg;
                                clip: true;

                                derive-page-scroll := ScrollView {
                                    x: 0px;
                                    y: 0px;
                                    width: parent.width;
                                    height: parent.height;
                                    horizontal-scrollbar-policy: ScrollBarPolicy.always-off;
                                    vertical-scrollbar-policy: ScrollBarPolicy.always-on;
                                    viewport-width: self.visible-width;
                                    viewport-height: max(self.visible-height, root.derive-content-height);

                                    derive-scroll-body := Rectangle {
                                        width: derive-page-scroll.visible-width;
                                        height: root.derive-content-height;
                                        background: transparent;

                                        derive-scroll-content := VerticalBox {
                                            width: parent.width;
                                            height: parent.height;
                                            spacing: root.derive-panel-gap;

                                            Panel {
                                                title: "新列生成";
                                                subtitle: "";
                                                horizontal-stretch: 1;
                                                height: 260px;

                                                VerticalBox {
                                                    spacing: 6px;

                                                    HorizontalBox {
                                                        spacing: 6px;

                                                        LabeledChoice {
                                                            width: 180px;
                                                            label: "动作";
                                                            model: [
                                                                "常量列",
                                                                "表达式计算列",
                                                                "条件判断列",
                                                                "拼接列",
                                                                "时间差列"
                                                            ];
                                                            value <=> FormState.derive-column-operation;
                                                        }

                                                        Rectangle {
                                                            horizontal-stretch: 1;
                                                            min-width: 0px;
                                                        }

                                                        InlineActionButton {
                                                            width: 88px;
                                                            label: "执行";
                                                            primary: true;
                                                            pressed => { Logic.apply-derive-column(); }
                                                        }
                                                    }

                                                    if FormState.derive-column-operation == "常量列": HorizontalBox {
                                                        spacing: 6px;

                                                        LabeledField {
                                                            width: 180px;
                                                            label: "列名";
                                                            placeholder: "source_name";
                                                            text <=> FormState.derive-constant-target;
                                                        }

                                                        LabeledField {
                                                            horizontal-stretch: 1;
                                                            label: "常量值";
                                                            placeholder: "offline";
                                                            text <=> FormState.derive-constant-value;
                                                        }

                                                        Rectangle {
                                                            horizontal-stretch: 1;
                                                            min-width: 0px;
                                                        }
                                                    }

                                                    if FormState.derive-column-operation == "表达式计算列": HorizontalBox {
                                                        spacing: 6px;

                                                        LabeledField {
                                                            width: 180px;
                                                            label: "输出列";
                                                            placeholder: "total_value";
                                                            text <=> FormState.derive-expression-target;
                                                        }

                                                        LabeledField {
                                                            horizontal-stretch: 1;
                                                            label: "表达式";
                                                            placeholder: "{price} * {qty}";
                                                            text <=> FormState.derive-expression;
                                                        }

                                                        Rectangle {
                                                            horizontal-stretch: 1;
                                                            min-width: 0px;
                                                        }
                                                    }

                                                    if FormState.derive-column-operation == "表达式计算列": Text {
                                                        color: AppTheme.text-soft;
                                                        font-size: 10px;
                                                        text: "用 {列名} 引用字段，支持 + - * / 和括号。";
                                                    }

                                                    if FormState.derive-column-operation == "条件判断列": HorizontalBox {
                                                        spacing: 6px;

                                                        LabeledField {
                                                            width: 150px;
                                                            label: "输出列";
                                                            placeholder: "status_flag";
                                                            text <=> FormState.derive-condition-target;
                                                        }

                                                        LabeledField {
                                                            width: 150px;
                                                            label: "条件列";
                                                            placeholder: "score";
                                                            text <=> FormState.derive-condition-source-column;
                                                        }

                                                        LabeledChoice {
                                                            width: 110px;
                                                            label: "运算符";
                                                            model: ["=", "!=", ">", ">=", "<", "<=", "包含", "为空"];
                                                            value <=> FormState.derive-condition-operator;
                                                        }

                                                        LabeledField {
                                                            width: 140px;
                                                            label: "条件值";
                                                            placeholder: "60";
                                                            text <=> FormState.derive-condition-value;
                                                        }

                                                        Rectangle {
                                                            horizontal-stretch: 1;
                                                            min-width: 0px;
                                                        }
                                                    }

                                                    if FormState.derive-column-operation == "条件判断列": HorizontalBox {
                                                        spacing: 6px;

                                                        LabeledField {
                                                            width: 150px;
                                                            label: "命中值";
                                                            placeholder: "合格";
                                                            text <=> FormState.derive-condition-true-value;
                                                        }

                                                        LabeledField {
                                                            width: 150px;
                                                            label: "未命中值";
                                                            placeholder: "不合格";
                                                            text <=> FormState.derive-condition-false-value;
                                                        }

                                                        Rectangle {
                                                            horizontal-stretch: 1;
                                                            min-width: 0px;
                                                        }
                                                    }

                                                    if FormState.derive-column-operation == "拼接列": HorizontalBox {
                                                        spacing: 6px;

                                                        LabeledField {
                                                            horizontal-stretch: 1;
                                                            label: "来源列";
                                                            placeholder: "province,city";
                                                            text <=> FormState.derive-concat-columns;
                                                        }

                                                        LabeledField {
                                                            width: 96px;
                                                            label: "分隔符";
                                                            placeholder: "_";
                                                            text <=> FormState.derive-concat-separator;
                                                        }

                                                        LabeledField {
                                                            width: 180px;
                                                            label: "输出列";
                                                            placeholder: "location";
                                                            text <=> FormState.derive-concat-target;
                                                        }

                                                        Rectangle {
                                                            horizontal-stretch: 1;
                                                            min-width: 0px;
                                                        }
                                                    }

                                                    if FormState.derive-column-operation == "时间差列": HorizontalBox {
                                                        spacing: 6px;

                                                        LabeledField {
                                                            width: 160px;
                                                            label: "开始列";
                                                            placeholder: "start_time";
                                                            text <=> FormState.derive-time-diff-start-column;
                                                        }

                                                        LabeledField {
                                                            width: 160px;
                                                            label: "结束列";
                                                            placeholder: "end_time";
                                                            text <=> FormState.derive-time-diff-end-column;
                                                        }

                                                        LabeledChoice {
                                                            width: 120px;
                                                            label: "单位";
                                                            model: ["分钟", "小时", "天", "秒"];
                                                            value <=> FormState.derive-time-diff-unit;
                                                        }

                                                        LabeledField {
                                                            width: 160px;
                                                            label: "输出列";
                                                            placeholder: "duration_min";
                                                            text <=> FormState.derive-time-diff-target;
                                                        }

                                                        Rectangle {
                                                            horizontal-stretch: 1;
                                                            min-width: 0px;
                                                        }
                                                    }
                                                }
                                            }

                                            Panel {
                                                title: "分组与聚合";
                                                subtitle: "";
                                                horizontal-stretch: 1;
                                                height: 148px;

                                                VerticalBox {
                                                    spacing: 6px;

                                                    HorizontalBox {
                                                        spacing: 6px;

                                                        LabeledField {
                                                            width: 260px;
                                                            label: "分组字段";
                                                            placeholder: "device_id,status";
                                                            text <=> FormState.derive-group-columns;
                                                        }

                                                        LabeledChoice {
                                                            width: 140px;
                                                            label: "聚合方式";
                                                            model: ["计数", "去重计数", "求和", "平均值", "最大值", "最小值"];
                                                            value <=> FormState.derive-group-function;
                                                        }

                                                        LabeledField {
                                                            width: 220px;
                                                            label: "目标字段";
                                                            placeholder: "value";
                                                            text <=> FormState.derive-group-target-column;
                                                        }

                                                        Rectangle {
                                                            horizontal-stretch: 1;
                                                            min-width: 0px;
                                                        }

                                                        InlineActionButton {
                                                            width: 88px;
                                                            label: "执行";
                                                            primary: true;
                                                            pressed => { Logic.apply-derive-group(); }
                                                        }
                                                    }

                                                    Text {
                                                        color: AppTheme.text-soft;
                                                        font-size: 10px;
                                                        text: "计数可以留空目标字段，其余聚合建议填写数值列。";
                                                    }
                                                }
                                            }

                                            Panel {
                                                title: "排序与排名";
                                                subtitle: "";
                                                horizontal-stretch: 1;
                                                height: 265px;

                                                VerticalBox {
                                                    spacing: 6px;

                                                    HorizontalBox {
                                                        spacing: 6px;

                                                        LabeledChoice {
                                                            width: 180px;
                                                            label: "动作";
                                                            model: ["单列排序", "多列排序", "条件优先排序", "生成排名列"];
                                                            value <=> FormState.derive-sort-operation;
                                                        }

                                                        Rectangle {
                                                            horizontal-stretch: 1;
                                                            min-width: 0px;
                                                        }

                                                        InlineActionButton {
                                                            width: 88px;
                                                            label: "执行";
                                                            primary: true;
                                                            pressed => { Logic.apply-derive-sort(); }
                                                        }
                                                    }

                                                    if FormState.derive-sort-operation == "单列排序": HorizontalBox {
                                                        spacing: 6px;

                                                        LabeledField {
                                                            width: 220px;
                                                            label: "排序列";
                                                            placeholder: "event_time";
                                                            text <=> FormState.derive-sort-column;
                                                        }

                                                        InlineToggleButton {
                                                            width: 88px;
                                                            label: FormState.derive-sort-ascending ? "升序" : "降序";
                                                            checked <=> FormState.derive-sort-ascending;
                                                        }
                                                    }

                                                    if FormState.derive-sort-operation == "多列排序" || FormState.derive-sort-operation == "条件优先排序" || FormState.derive-sort-operation == "生成排名列": HorizontalBox {
                                                        spacing: 6px;

                                                        LabeledField {
                                                            horizontal-stretch: 1;
                                                            label: "排序列";
                                                            placeholder: "event_time,device_id";
                                                            text <=> FormState.derive-sort-columns;
                                                        }

                                                        LabeledField {
                                                            width: 220px;
                                                            label: "排序方向";
                                                            placeholder: "升序,降序";
                                                            text <=> FormState.derive-sort-orders;
                                                        }
                                                    }

                                                    if FormState.derive-sort-operation == "条件优先排序": HorizontalBox {
                                                        spacing: 6px;

                                                        LabeledField {
                                                            width: 160px;
                                                            label: "条件列";
                                                            placeholder: "priority_flag";
                                                            text <=> FormState.derive-priority-column;
                                                        }

                                                        LabeledChoice {
                                                            width: 110px;
                                                            label: "运算符";
                                                            model: ["=", "!=", ">", ">=", "<", "<=", "包含", "为空"];
                                                            value <=> FormState.derive-priority-operator;
                                                        }

                                                        LabeledField {
                                                            width: 140px;
                                                            label: "条件值";
                                                            placeholder: "1";
                                                            text <=> FormState.derive-priority-value;
                                                        }

                                                        LabeledChoice {
                                                            width: 120px;
                                                            label: "位置";
                                                            model: ["优先置前", "优先置后"];
                                                            value <=> FormState.derive-priority-placement;
                                                        }
                                                    }

                                                    if FormState.derive-sort-operation == "生成排名列": HorizontalBox {
                                                        spacing: 6px;

                                                        LabeledField {
                                                            width: 180px;
                                                            label: "输出列";
                                                            placeholder: "rank";
                                                            text <=> FormState.derive-rank-output-column;
                                                        }
                                                    }
                                                }
                                            }

                                            Panel {
                                                title: "窗口类处理";
                                                subtitle: "";
                                                horizontal-stretch: 1;
                                                height: 300px;

                                                VerticalBox {
                                                    spacing: 6px;

                                                    HorizontalBox {
                                                        spacing: 6px;

                                                        LabeledChoice {
                                                            width: 180px;
                                                            label: "动作";
                                                            model: ["滚动统计", "累积和", "滑动平均", "邻近值比较"];
                                                            value <=> FormState.derive-window-operation;
                                                        }

                                                        Rectangle {
                                                            horizontal-stretch: 1;
                                                            min-width: 0px;
                                                        }

                                                        InlineActionButton {
                                                            width: 88px;
                                                            label: "执行";
                                                            primary: true;
                                                            pressed => { Logic.apply-derive-window(); }
                                                        }
                                                    }

                                                    HorizontalBox {
                                                        spacing: 6px;

                                                        LabeledField {
                                                            width: 180px;
                                                            label: "排序列";
                                                            placeholder: "event_time";
                                                            text <=> FormState.derive-window-order-column;
                                                        }

                                                        LabeledField {
                                                            width: 220px;
                                                            label: "分组列";
                                                            placeholder: "device_id";
                                                            text <=> FormState.derive-window-group-columns;
                                                        }

                                                        if FormState.derive-window-operation == "滚动统计" || FormState.derive-window-operation == "滑动平均": LabeledField {
                                                            width: 120px;
                                                            label: "窗口大小";
                                                            placeholder: "3";
                                                            text <=> FormState.derive-window-size;
                                                        }

                                                        if FormState.derive-window-operation == "滚动统计": LabeledChoice {
                                                            width: 140px;
                                                            label: "统计方式";
                                                            model: ["求和", "平均值", "最大值", "最小值", "计数", "去重计数"];
                                                            value <=> FormState.derive-window-function;
                                                        }

                                                        if FormState.derive-window-operation == "邻近值比较": LabeledChoice {
                                                            width: 140px;
                                                            label: "比较方式";
                                                            model: ["差值", "变化率", "是否上升", "是否下降"];
                                                            value <=> FormState.derive-window-compare-mode;
                                                        }

                                                        Rectangle {
                                                            horizontal-stretch: 1;
                                                            min-width: 0px;
                                                        }
                                                    }

                                                    HorizontalBox {
                                                        spacing: 6px;

                                                        LabeledField {
                                                            width: 180px;
                                                            label: "目标列";
                                                            placeholder: "value";
                                                            text <=> FormState.derive-window-target-column;
                                                        }

                                                        LabeledField {
                                                            width: 180px;
                                                            label: "输出列";
                                                            placeholder: "value_window";
                                                            text <=> FormState.derive-window-output-column;
                                                        }

                                                        Rectangle {
                                                            horizontal-stretch: 1;
                                                            min-width: 0px;
                                                        }
                                                    }
                                                }
                                            }

                                            Rectangle {
                                                height: root.derive-bottom-padding;
                                                background: transparent;
                                            }
                                        }
                                    }
                                }
                            }

                            join-page := Rectangle {
                                visible: root.active-tab == 4;
                                x: 0px;
                                y: 0px;
                                width: parent.width;
                                height: parent.height;
                                background: AppTheme.window-bg;
                                clip: true;

                                join-page-scroll := ScrollView {
                                    x: 0px;
                                    y: 0px;
                                    width: parent.width;
                                    height: parent.height;
                                    horizontal-scrollbar-policy: ScrollBarPolicy.always-off;
                                    vertical-scrollbar-policy: ScrollBarPolicy.always-on;
                                    viewport-width: self.visible-width;
                                    viewport-height: max(self.visible-height, join-scroll-content.preferred-height);

                                    join-scroll-body := Rectangle {
                                        width: join-page-scroll.visible-width;
                                        height: max(join-page-scroll.visible-height, join-scroll-content.preferred-height);
                                        background: transparent;

                                        join-scroll-content := VerticalBox {
                                            width: parent.width;
                                            spacing: root.join-panel-gap;

                                            Panel {
                                                title: "关联方式";
                                                subtitle: FormState.join-kind == "内连接"
                                                    ? "仅保留左右表都能匹配到的记录，适合强调精确命中的融合。"
                                                    : FormState.join-kind == "外连接"
                                                    ? "保留左右表全部记录，未匹配字段会出现空值，适合先全面对齐再回查。"
                                                    : "";
                                                horizontal-stretch: 1;

                                                HorizontalBox {
                                                    spacing: 6px;

                                                    LabeledChoice {
                                                        width: 180px;
                                                        label: "连接类型";
                                                        model: ["左连接", "内连接", "外连接"];
                                                        value <=> FormState.join-kind;
                                                    }

                                                    Rectangle {
                                                        horizontal-stretch: 1;
                                                        min-width: 0px;
                                                    }

                                                    InlineActionButton {
                                                        width: 96px;
                                                        label: "执行融合";
                                                        primary: true;
                                                        pressed => { Logic.apply-join(); }
                                                    }
                                                }
                                            }

                                            Panel {
                                                title: "融合场景";
                                                subtitle: "";
                                                horizontal-stretch: 1;

                                                VerticalBox {
                                                    spacing: 6px;

                                                    LabeledChoice {
                                                        width: 280px;
                                                        label: "场景模板";
                                                        model: [
                                                            "试验采样数据 + 指标汇总表",
                                                            "设备状态数据 + 测试结果数据",
                                                            "仿真结果数据 + 实测数据",
                                                            "配置参数 + 输出结果"
                                                        ];
                                                        value <=> FormState.join-scene;
                                                    }

                                                    Text {
                                                        color: AppTheme.text-soft;
                                                        font-size: 10px;
                                                        wrap: word-wrap;
                                                        text: FormState.join-scene == "设备状态数据 + 测试结果数据"
                                                            ? "优先考虑设备编号、批次号或测试序列号作为匹配键。"
                                                            : FormState.join-scene == "仿真结果数据 + 实测数据"
                                                            ? "优先统一工况编号、时刻点或试验编号后再做融合。"
                                                            : FormState.join-scene == "配置参数 + 输出结果"
                                                            ? "优先使用配置编号、版本号或参数组编码。"
                                                            : "";
                                                    }
                                                }
                                            }

                                            Panel {
                                                title: "融合过程控制";
                                                subtitle: "先确认主表和目标表，再填写两侧匹配字段与冲突字段处理方式。";
                                                horizontal-stretch: 1;

                                                VerticalBox {
                                                    spacing: 6px;

                                                    HorizontalBox {
                                                        spacing: 6px;

                                                        Rectangle {
                                                            horizontal-stretch: 1;
                                                            min-width: 0px;
                                                            min-height: 54px;
                                                            background: AppTheme.panel-muted;
                                                            border-width: 1px;
                                                            border-color: AppTheme.border;
                                                            border-radius: 3px;

                                                            VerticalBox {
                                                                width: parent.width;
                                                                height: parent.height;
                                                                padding-left: 8px;
                                                                padding-right: 8px;
                                                                padding-top: 6px;
                                                                padding-bottom: 6px;
                                                                spacing: 4px;

                                                                Text {
                                                                    text: "主表";
                                                                    color: AppTheme.text-soft;
                                                                    font-size: 10px;
                                                                    font-weight: 600;
                                                                }

                                                                Text {
                                                                    text: AppState.current-dataset-name;
                                                                    color: AppTheme.text;
                                                                    font-size: 11px;
                                                                    font-weight: 700;
                                                                    wrap: no-wrap;
                                                                }
                                                            }
                                                        }

                                                        LabeledField {
                                                            width: 200px;
                                                            label: "目标数据集编号";
                                                            placeholder: "2";
                                                            text <=> FormState.join-dataset-id;
                                                        }

                                                        InlineActionButton {
                                                            width: 96px;
                                                            label: "执行融合";
                                                            primary: true;
                                                            pressed => { Logic.apply-join(); }
                                                        }
                                                    }

                                                    HorizontalBox {
                                                        spacing: 6px;

                                                        LabeledField {
                                                            width: 240px;
                                                            label: "主表匹配字段";
                                                            placeholder: "device_id";
                                                            text <=> FormState.join-left-key;
                                                        }

                                                        LabeledField {
                                                            width: 240px;
                                                            label: "目标表匹配字段";
                                                            placeholder: "device_id";
                                                            text <=> FormState.join-right-key;
                                                        }

                                                        Rectangle {
                                                            horizontal-stretch: 1;
                                                            min-width: 0px;
                                                        }
                                                    }

                                                    HorizontalBox {
                                                        spacing: 6px;

                                                        LabeledChoice {
                                                            width: 200px;
                                                            label: "冲突字段命名";
                                                            model: [
                                                                "冲突列追加_right",
                                                                "冲突列追加right前缀",
                                                                "仅保留主表字段"
                                                            ];
                                                            value <=> FormState.join-conflict-mode;
                                                        }

                                                        InfoCard {
                                                            horizontal-stretch: 1;
                                                            card-min-height: 54px;
                                                            title: "可选目标 / 结果预览";
                                                            value: AppState.join-target-hint + "执行后会生成新的融合结果数据集并自动切换。";
                                                        }
                                                    }
                                                }
                                            }

                                            Panel {
                                                title: "融合结果检查";
                                                subtitle: "执行融合后在这里查看匹配结果与风险提示。";
                                                horizontal-stretch: 1;

                                                VerticalBox {
                                                    spacing: 6px;

                                                    HorizontalBox {
                                                        spacing: 6px;

                                                        InfoCard {
                                                            horizontal-stretch: 1;
                                                            card-min-height: 72px;
                                                            title: "成功匹配数";
                                                            value: AppState.join-match-summary;
                                                        }

                                                        InfoCard {
                                                            horizontal-stretch: 1;
                                                            card-min-height: 72px;
                                                            title: "未匹配数";
                                                            value: AppState.join-unmatched-summary;
                                                        }
                                                    }

                                                    HorizontalBox {
                                                        spacing: 6px;

                                                        InfoCard {
                                                            horizontal-stretch: 1;
                                                            card-min-height: 72px;
                                                            title: "冲突字段清单";
                                                            value: AppState.join-conflict-summary;
                                                        }

                                                        InfoCard {
                                                            horizontal-stretch: 1;
                                                            card-min-height: 72px;
                                                            title: "数据丢失提示";
                                                            value: AppState.join-loss-summary;
                                                        }
                                                    }
                                                }
                                            }

                                            Rectangle {
                                                height: root.join-bottom-padding;
                                                background: transparent;
                                            }
                                        }
                                    }
                                }
                            }

                            pipeline-page := Rectangle {
                                visible: root.active-tab == 5;
                                x: 0px;
                                y: 0px;
                                width: parent.width;
                                height: parent.height;
                                background: AppTheme.window-bg;
                                clip: true;

                                pipeline-page-scroll := ScrollView {
                                    x: 0px;
                                    y: 0px;
                                    width: parent.width;
                                    height: parent.height;
                                    horizontal-scrollbar-policy: ScrollBarPolicy.always-off;
                                    vertical-scrollbar-policy: ScrollBarPolicy.always-on;
                                    viewport-width: self.visible-width;
                                    viewport-height: max(self.visible-height, pipeline-scroll-content.preferred-height);

                                    pipeline-scroll-body := Rectangle {
                                        width: pipeline-page-scroll.visible-width;
                                        height: max(pipeline-page-scroll.visible-height, pipeline-scroll-content.preferred-height);
                                        background: transparent;

                                        pipeline-scroll-content := VerticalBox {
                                            width: parent.width;
                                            spacing: root.pipeline-panel-gap;

                                            Panel {
                                                title: "流程模板";
                                                subtitle: "";
                                                horizontal-stretch: 1;

                                                HorizontalBox {
                                                    spacing: 6px;

                                                    Button {
                                                        text: "保存流程模板";
                                                        height: 28px;
                                                        clicked => { Logic.save-pipeline-template(); }
                                                    }

                                                    Button {
                                                        text: "回放流程模板";
                                                        height: 28px;
                                                        clicked => { Logic.replay-pipeline-template(); }
                                                    }

                                                    Rectangle {
                                                        horizontal-stretch: 1;
                                                    }
                                                }
                                            }

                                            Panel {
                                                title: "流程记录";
                                                subtitle: "";

                                                VerticalBox {
                                                    height: 520px;
                                                    spacing: 0px;

                                                    HorizontalBox {
                                                        spacing: 0px;

                                                        LedgerHeaderCell {
                                                            cell-width: 78px;
                                                            label: "时间";
                                                            center: true;
                                                        }

                                                        LedgerHeaderCell {
                                                            cell-width: 160px;
                                                            label: "动作";
                                                        }

                                                        LedgerHeaderCell {
                                                            cell-width: 430px;
                                                            label: "明细";
                                                        }

                                                        LedgerHeaderCell {
                                                            cell-width: 280px;
                                                            label: "结果";
                                                        }
                                                    }

                                                    step-scroll := ScrollView {
                                                        vertical-stretch: 1;
                                                        horizontal-scrollbar-policy: ScrollBarPolicy.always-off;
                                                        vertical-scrollbar-policy: ScrollBarPolicy.always-on;
                                                        viewport-width: step-scroll.visible-width;
                                                        viewport-height: max(step-scroll.visible-height, step-rows.preferred-height);

                                                        step-rows := VerticalBox {
                                                            x: 0px;
                                                            y: 0px;
                                                            width: step-scroll.visible-width;
                                                            spacing: 0px;

                                                            for step in AppState.steps: StepRow {
                                                                time: step.time;
                                                                action: step.action;
                                                                detail: step.detail;
                                                                outcome: step.outcome;
                                                            }
                                                        }
                                                    }
                                                }
                                            }

                                            Rectangle {
                                                height: root.pipeline-bottom-padding;
                                                background: transparent;
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
