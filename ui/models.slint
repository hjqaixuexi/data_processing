    callback import-files();
    callback select-dataset(int);
    callback delete-selected-dataset();
    callback refresh-current();
    callback apply-preview-settings();
    callback preview-prev-page();
    callback preview-next-page();
    callback apply-field-settings();
    callback field-prev-page();
    callback field-next-page();
    callback apply-quality-rules();
    callback undo();
    callback redo();
    callback normalize-columns();
    callback trim-text-values();
    callback drop-empty-rows();
    callback deduplicate-rows();
    callback apply-rename();
    callback apply-keep-columns();
    callback apply-drop-columns();
    callback apply-sort();
    callback apply-fill-null();
    callback apply-fill-forward();
    callback apply-cast-column();
    callback apply-row-operation();
    callback apply-text-operation();
    callback apply-value-operation();
    callback apply-filter-contains();
    callback apply-keep-range();
    callback apply-keep-top-rows();
    callback apply-sample-rows();
    callback apply-drop-missing-rows();
    callback apply-text-case();
    callback apply-replace-text();
    callback apply-round-numeric();
    callback apply-group-aggregate();
    callback apply-recommended-mapping();
    callback apply-join();
    callback export-csv();
    callback export-json();
    callback export-quality-report();
    callback save-pipeline-template();
    callback replay-pipeline-template();
}
