export struct DatasetCardData {
    dataset-id: int,
    name: string,
    format: string,
    size-label: string,
    imported-at: string,
    import-duration: string,
    sheet-name: string,
    overview: string,
    key-hint: string,
    time-hint: string,
}

export struct MetricCardData {
    title: string,
    value: string,
    detail: string,
}

export struct ColumnRowData {
    name: string,
    dtype: string,
    non-null: string,
    missing-count: string,
    missing-rate: string,
    unique-count: string,
    sample-value: string,
    role-hint: string,
}

export struct PreviewRowData {
    row-label: string,
    cells: [string],
}

export struct IssueRowData {
    category: string,
    severity: string,
    field: string,
    detail: string,
}

export struct StepRowData {
    time: string,
    action: string,
    detail: string,
    outcome: string,
}

export struct MappingRowData {
    source-name: string,
    target-name: string,
    confidence: string,
    status: string,
}

export struct JoinSuggestionData {
    target-dataset: string,
    left-key: string,
    right-key: string,
    join-type: string,
    reason: string,
}

export struct FusionHintData {
    dataset-id: string,
    dataset-name: string,
    role-hint: string,
    object-hint: string,
    time-hint: string,
    note: string,
}

export global AppState {
    in property <[DatasetCardData]> datasets;
    in property <[MetricCardData]> metrics;
    in property <[ColumnRowData]> columns;
    in property <[string]> preview-columns;
    in property <[PreviewRowData]> preview-rows;
    in property <[IssueRowData]> issues;
    in property <[StepRowData]> steps;
    in property <[MappingRowData]> mappings;
    in property <[JoinSuggestionData]> join-suggestions;
    in property <[FusionHintData]> fusion-hints;
    in property <string> current-dataset-name;
    in property <string> current-dataset-overview;
    in property <string> quality-summary;
    in property <string> quality-rule-summary;
    in property <string> active-count-label;
    in property <string> status-message;
    in property <string> preview-page-label;
    in property <string> preview-range-label;
    in property <string> field-page-label;
    in property <string> field-range-label;
    in property <int> field-page-size;
    in property <int> selected-dataset-id;
    in property <bool> can-undo;
    in property <bool> can-redo;
    in property <bool> can-preview-prev;
    in property <bool> can-preview-next;
    in property <bool> can-field-prev;
    in property <bool> can-field-next;
    in property <string> join-target-hint;
    in property <string> join-match-summary;
    in property <string> join-unmatched-summary;
    in property <string> join-conflict-summary;
    in property <string> join-loss-summary;
    in property <string> fusion-source-hint;
    in property <string> fusion-source-summary;
    in property <string> fusion-alignment-summary;
    in property <string> fusion-quality-summary;
    in property <string> fusion-output-summary;
    in property <string> fusion-trace-summary;
    in property <[string]> visualization-all-columns;
    in property <[string]> visualization-numeric-columns;
    in property <image> visualization-preview-image;
    in property <string> visualization-preview-summary;
    in property <string> visualization-preview-path;
    in property <string> visualization-suggestion-summary;
}

